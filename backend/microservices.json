[
  {
    "name": "send_notification",
    "description": "Send a notification or message to a recipient.",
    "endpoint": "http://localhost:8001/notify",
    "method": "POST",
    "args_schema": {
      "type": "object",
      "properties": {
        "to":      { "type": "string", "description": "Recipient email or username", "x-param-style": "body" },
        "message": { "type": "string", "description": "Notification message body", "x-param-style": "body" }
      },
      "required": ["to", "message"]
    },
    "response_schema": {
      "type": "object",
      "properties": {
        "to":        { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["to", "timestamp"]
    },
    "args_example": { "to": "admin@example.com", "message": "Server is down!" },
    "response_example": { "to": "admin@example.com", "timestamp": "2026-03-21T10:00:00Z" }
  },
  {
    "name": "get_random_number",
    "description": "Generate a random number between min and max (inclusive). Default range is 1 to 100.",
    "endpoint": "http://localhost:8001/random-number",
    "method": "POST",
    "args_schema": {
      "type": "object",
      "properties": {
        "min": { "type": "integer", "description": "Lower bound (inclusive). Default: 1", "default": 1, "x-param-style": "body" },
        "max": { "type": "integer", "description": "Upper bound (inclusive). Default: 100", "default": 100, "x-param-style": "body" }
      },
      "required": []
    },
    "response_schema": {
      "type": "object",
      "properties": {
        "min":    { "type": "integer" },
        "max":    { "type": "integer" },
        "number": { "type": "integer" }
      },
      "required": ["min", "max", "number"]
    },
    "args_example": { "min": 1, "max": 50 },
    "response_example": { "min": 1, "max": 50, "number": 23 }
  },
  {
    "name": "crud_data",
    "description": "Create, read, update, or delete data in an external system.",
    "endpoint": "http://localhost:8001/data",
    "method": "POST",
    "args_schema": {
      "type": "object",
      "properties": {
        "action":   { "type": "string", "enum": ["create", "read", "update", "delete"], "description": "Operation to perform", "x-param-style": "body" },
        "resource": { "type": "string", "description": "Target resource name, e.g. 'users' or 'orders'", "x-param-style": "body" },
        "data":     { "type": "object", "description": "Payload for create/update. Optional for read/delete.", "default": {}, "x-param-style": "body" }
      },
      "required": ["action", "resource"]
    },
    "response_schema": {
      "type": "object",
      "properties": {
        "success": { "type": "boolean" },
        "data":    { "type": "object" }
      },
      "required": ["success", "data"]
    },
    "args_example": { "action": "read", "resource": "users", "data": {} },
    "response_example": { "success": true, "data": { "id": "123", "name": "John" } }
  }
]
